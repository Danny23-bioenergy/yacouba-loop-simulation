        "# =============================================================================\n",
        "# THE YACOUBA LOOP — Monte Carlo Simulation (v3)\n",
        "# Author  : Danny Nawa Muyunda\n",
        "#           Independent Researcher | Copperbelt University, Zambia\n",
        "#           \"One World, One People\"\n",
        "# =============================================================================\n",
        "# RECOMMENDED PARAMETERS — Kitwe / Copperbelt context\n",
        "#   Starting Biomass : 400 to 800 kg/ha  (degraded mine-affected to recovering land)\n",
        "#   Livestock Count  : 0.1 to 0.7 animals/ha (light to moderate stocking rate)\n",
        "#   These ranges reflect Copperbelt degraded land conditions.\n",
        "#   Rainfall model uses real Kitwe monthly averages (Nov–Mar rainy season).\n",
        "#   Source: Weather Atlas / climate-data.org (1999–2019 averages)\n",
        "#\n",
        "# WHAT'S NEW IN v3\n",
        "#   - Heavy metal toxicity factor added\n",
        "#   - Without the loop: toxicity stays constant, permanently suppressing growth\n",
        "#   - With the loop: biochar progressively immobilises copper and cobalt\n",
        "#     each month, reducing toxicity and unlocking growth potential\n",
        "#   - This reflects real Copperbelt mine-affected land conditions\n",
        "#   - Source: Gwanama et al. (2022) Scientific Reports CBU\n",
        "# =============================================================================\n",
        "\n",
        "import random\n",
        "import statistics\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.patches as mpatches\n",
        "\n",
        "# --- SCIENCE CONSTANTS — calibrated for Kitwe, Copperbelt, Zambia ---\n",
        "MONTHLY_CONSUMPTION  = 185   # kg per animal per month (FAO Standard)\n",
        "GROWTH_COEFF         = 3.8   # kg of new grass per 1 mm of rain\n",
        "# Kitwe Copperbelt calibration:\n",
        "#   Sahel degraded dryland baseline  = 2.4 kg/mm\n",
        "#   Healthy Zambian grassland        = 5.0+ kg/mm\n",
        "#   Mine-affected Copperbelt (this)  = 3.8 kg/mm\n",
        "#   Suppressed by soil compaction and heavy metal contamination\n",
        "#   but higher than Sahel due to greater rainfall and better soil development\n",
        "MANURE_RATE          = 0.30  # 30% of consumed grass returns as manure\n",
        "BIOCHAR_CONVERSION   = 0.15  # 15% of manure converts to biochar benefit\n",
        "#   Note: 15% is an optimistic estimate accounting for losses due to\n",
        "#   weathering, collection inefficiency, and drying before pyrolysis.\n",
        "RESTORATION_BOOST    = 0.80  # 80% average synergy (Zai Pits + Biochar)\n",
        "\n",
        "# --- HEAVY METAL TOXICITY CONSTANTS ---\n",
        "# Mine-affected Kitwe land has copper and cobalt contamination\n",
        "# that suppresses grass growth by reducing germination and root development.\n",
        "# Without biochar: toxicity is permanent — grass growth is suppressed every month.\n",
        "# With biochar: heavy metals are progressively immobilised each month,\n",
        "# reducing toxicity and unlocking the land's full growth potential.\n",
        "# Source: Gwanama et al. (2022) Scientific Reports CBU\n",
        "#         Ippolito et al. (2024) Int. Journal of Environmental Science\n",
        "INITIAL_TOXICITY    = 0.45   # 45% growth suppression on mine-affected land\n",
        "BIOCHAR_DETOX_RATE  = 0.08   # 8% toxicity reduction per month with biochar\n",
        "MIN_TOXICITY        = 0.05   # 5% residual suppression always remains\n",
        "#   Note: INITIAL_TOXICITY of 0.45 reflects moderately contaminated\n",
        "#   Copperbelt land. Heavily contaminated sites (BM, TD26) may be higher.\n",
        "#   MIN_TOXICITY reflects the fact that full remediation takes many seasons.\n",
        "\n",
        "# --- RAINFALL MODEL — Kitwe, Zambia (Copperbelt) ---\n",
        "# Kitwe rainy season: November to March (5 months simulated)\n",
        "# Real monthly averages (mm): Nov=91, Dec=208, Jan=289, Feb=184, Mar=165\n",
        "# Source: Weather Atlas / climate-data.org (1999–2019 averages)\n",
        "# Dry season (May–September) has essentially zero rainfall — not simulated.\n",
        "# Profiles represent year-to-year variability around these averages.\n",
        "RAINFALL_PROFILES = [\n",
        "    [85,  200, 280, 175, 155],   # typical moderate season\n",
        "    [60,  170, 260, 150, 130],   # below average / dry season\n",
        "    [110, 230, 310, 200, 180],   # above average / wet season\n",
        "    [40,  140, 220, 120, 100],   # poor / drought season (El Nino type)\n",
        "    [130, 260, 340, 220, 200],   # exceptional / flood risk season\n",
        "]\n",
        "# Months represented: November, December, January, February, March\n",
        "\n",
        "def kitwe_rainfall():\n",
        "    \"\"\"Return monthly rainfall (mm) for one simulated 5-month Kitwe rainy season.\n",
        "    Profiles based on real Kitwe Copperbelt climate data (Weather Atlas, 1999-2019).\n",
        "    \"\"\"\n",
        "    profile = random.choice(RAINFALL_PROFILES)\n",
        "    return [max(5, v + random.uniform(-v*0.15, v*0.15)) for v in profile]\n",
        "\n",
        "\n",
        "# --- CORE SIMULATION ---\n",
        "def simulate_season(start_grass, animals, system_active):\n",
        "    \"\"\"\n",
        "    Simulate one 5-month Kitwe rainy season (November to March).\n",
        "\n",
        "    Heavy metal toxicity behaviour:\n",
        "      - WITHOUT loop: toxicity stays at INITIAL_TOXICITY every month.\n",
        "        Copper and cobalt permanently suppress grass growth.\n",
        "      - WITH loop: biochar immobilises heavy metals progressively.\n",
        "        Toxicity reduces by BIOCHAR_DETOX_RATE each month,\n",
        "        flooring at MIN_TOXICITY. Growth unlocks as land detoxifies.\n",
        "\n",
        "    Returns a list of 6 biomass values: [start, Nov, Dec, Jan, Feb, Mar]\n",
        "    \"\"\"\n",
        "    grass = start_grass\n",
        "    history = [grass]\n",
        "    monthly_rain = kitwe_rainfall()\n",
        "\n",
        "    for month in range(5):\n",
        "\n",
        "        # --- TOXICITY CALCULATION ---\n",
        "        if system_active:\n",
        "            # Biochar progressively immobilises heavy metals\n",
        "            # Toxicity reduces each month as biochar works into soil\n",
        "            toxicity = max(\n",
        "                MIN_TOXICITY,\n",
        "                INITIAL_TOXICITY - (BIOCHAR_DETOX_RATE * (month + 1))\n",
        "            )\n",
        "        else:\n",
        "            # No biochar — heavy metals remain in soil permanently\n",
        "            # Toxicity stays constant at initial level all season\n",
        "            toxicity = INITIAL_TOXICITY\n",
        "\n",
        "        # --- GRAZING ---\n",
        "        # Livestock reduce intake when grass is scarce (real behaviour)\n",
        "        grazing_pressure = min(1.0, grass / (animals * MONTHLY_CONSUMPTION))\n",
        "        consumed = animals * MONTHLY_CONSUMPTION * grazing_pressure\n",
        "        grass = max(0, grass - consumed)\n",
        "\n",
        "        # --- RAINFALL-DRIVEN REGROWTH ---\n",
        "        rainfall   = monthly_rain[month]\n",
        "        new_growth = rainfall * GROWTH_COEFF\n",
        "\n",
        "        # --- TOXICITY SUPPRESSION APPLIED TO GROWTH ---\n",
        "        # Heavy metals reduce germination and root development\n",
        "        # Toxicity factor reduces effective growth regardless of rainfall\n",
        "        new_growth = new_growth * (1 - toxicity)\n",
        "\n",
        "        # --- RESTORATION SYNERGY (loop only) ---\n",
        "        if system_active:\n",
        "            water_bonus   = new_growth * RESTORATION_BOOST\n",
        "            manure_kg     = consumed   * MANURE_RATE\n",
        "            biochar_bonus = manure_kg  * BIOCHAR_CONVERSION\n",
        "            new_growth   += water_bonus + biochar_bonus\n",
        "\n",
        "        grass = max(0, grass + new_growth)\n",
        "        history.append(grass)\n",
        "\n",
        "    return history\n",
        "\n",
        "\n",
        "# --- MONTE CARLO WRAPPER ---\n",
        "def monte_carlo(n_runs, start_grass, animals, system_active):\n",
        "    \"\"\"\n",
        "    Run the simulation n_runs times.\n",
        "    Returns:\n",
        "        finals   — list of final biomass values (March of each run)\n",
        "        medians  — median biomass at each of the 6 time points\n",
        "    \"\"\"\n",
        "    all_histories = [\n",
        "        simulate_season(start_grass, animals, system_active)\n",
        "        for _ in range(n_runs)\n",
        "    ]\n",
        "\n",
        "    finals  = [h[5] for h in all_histories]\n",
        "    medians = [\n",
        "        statistics.median(h[m] for h in all_histories)\n",
        "        for m in range(6)\n",
        "    ]\n",
        "    return finals, medians\n",
        "\n",
        "\n",
        "# --- RESULTS ANALYSIS ---\n",
        "def recovery_probability(finals, threshold):\n",
        "    \"\"\"Percentage of runs where final biomass exceeds threshold.\"\"\"\n",
        "    above = sum(1 for f in finals if f >= threshold)\n",
        "    return round(above / len(finals) * 100, 1)\n",
        "\n",
        "def land_health_label(biomass):\n",
        "    if biomass > 2000:  return \"THRIVING  — Land Recovering Well\"\n",
        "    if biomass >= 1000: return \"STABLE    — Holding Ground\"\n",
        "    if biomass >= 500:  return \"STRESSED  — Restoration Recommended\"\n",
        "    return                     \"DEGRADED  — Critical Intervention Needed\"\n",
        "\n",
        "\n",
        "# --- PLOTTING ---\n",
        "GREEN  = \"#3B6D11\"\n",
        "AMBER  = \"#854F0B\"\n",
        "GREY   = \"#888780\"\n",
        "\n",
        "def plot_results(with_finals, no_finals, with_medians, no_medians):\n",
        "    months = [\"Start\", \"November\", \"December\", \"January\", \"February\", \"March\"]\n",
        "    fig, axes = plt.subplots(1, 2, figsize=(13, 5))\n",
        "    fig.suptitle(\n",
        "        \"Yacouba Loop — Monte Carlo Simulation v3 (Kitwe, Copperbelt — Zambia)\\n\"\n",
        "        \"Danny Nawa Muyunda · Copperbelt University · One World, One People\",\n",
        "        fontsize=11, y=1.01\n",
        "    )\n",
        "\n",
        "    # --- Left: Median trajectory ---\n",
        "    ax1 = axes[0]\n",
        "    ax1.plot(months, with_medians, color=GREEN, marker=\"o\", linewidth=2.2,\n",
        "             label=\"With Yacouba Loop\")\n",
        "    ax1.plot(months, no_medians,   color=AMBER, marker=\"s\", linewidth=2.2,\n",
        "             linestyle=\"--\", label=\"Without Yacouba Loop\", alpha=0.8)\n",
        "    ax1.fill_between(months, with_medians, no_medians,\n",
        "                     where=[w > n for w,n in zip(with_medians, no_medians)],\n",
        "                     alpha=0.08, color=GREEN)\n",
        "    ax1.set_title(\"Median Biomass Trajectory — Kitwe Rainy Season\", fontsize=10)\n",
        "    ax1.set_ylabel(\"Field Biomass (kg/ha)\")\n",
        "    ax1.legend(fontsize=9)\n",
        "    ax1.grid(axis=\"y\", alpha=0.3)\n",
        "    ax1.tick_params(axis=\"x\", rotation=20)\n",
        "\n",
        "    # --- Right: Distribution of final biomass ---\n",
        "    ax2 = axes[1]\n",
        "    bins = [0, 500, 1000, 1500, 2000, 2500, 3000, 4000, 6000]\n",
        "    n = len(with_finals)\n",
        "    with_counts = [sum(1 for f in with_finals if bins[i] <= f < bins[i+1]) / n * 100\n",
        "                   for i in range(len(bins)-1)]\n",
        "    no_counts   = [sum(1 for f in no_finals   if bins[i] <= f < bins[i+1]) / n * 100\n",
        "                   for i in range(len(bins)-1)]\n",
        "    labels = [\"<500\",\"500-1k\",\"1k-1.5k\",\"1.5k-2k\",\"2k-2.5k\",\"2.5k-3k\",\"3k-4k\",\"4k+\"]\n",
        "    x = range(len(labels))\n",
        "    w = 0.38\n",
        "    ax2.bar([i - w/2 for i in x], with_counts, width=w, color=GREEN,\n",
        "            alpha=0.82, label=\"With Yacouba Loop\")\n",
        "    ax2.bar([i + w/2 for i in x], no_counts,   width=w, color=AMBER,\n",
        "            alpha=0.65, label=\"Without Yacouba Loop\")\n",
        "    ax2.set_title(\"Final Biomass Distribution (March — End of Season)\", fontsize=10)\n",
        "    ax2.set_ylabel(\"% of runs\")\n",
        "    ax2.set_xticks(list(x))\n",
        "    ax2.set_xticklabels(labels, rotation=30, ha=\"right\", fontsize=8)\n",
        "    ax2.legend(fontsize=9)\n",
        "    ax2.grid(axis=\"y\", alpha=0.3)\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(\"yacouba_loop_kitwe_v3_results.png\", dpi=150, bbox_inches=\"tight\")\n",
        "    print(\"\\nChart saved: yacouba_loop_kitwe_v3_results.png\")\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# --- USER INPUT ---\n",
        "def get_inputs():\n",
        "    print(\"=\" * 60)\n",
        "    print(\"  THE YACOUBA LOOP — Monte Carlo Simulation (v3)\")\n",
        "    print(\"  Kitwe, Copperbelt — Zambia\")\n",
        "    print(\"  Heavy metal toxicity factor included\")\n",
        "    print(\"  Danny Nawa Muyunda · Copperbelt University\")\n",
        "    print(\"=\" * 60)\n",
        "    print(f\"\\n  Toxicity model: {INITIAL_TOXICITY*100:.0f}% initial growth suppression\")\n",
        "    print(f\"  Without loop  : toxicity stays at {INITIAL_TOXICITY*100:.0f}% all season\")\n",
        "    print(f\"  With loop     : reduces by {BIOCHAR_DETOX_RATE*100:.0f}% per month via biochar\")\n",
        "    print(f\"  Minimum floor : {MIN_TOXICITY*100:.0f}% residual suppression\")\n",
        "    print(f\"\\nRecommended: Biomass 400-800 kg/ha | Livestock 0.1-0.7/ha\\n\")\n",
        "    grass   = int(input(\"Starting Biomass (kg/ha)           : \"))\n",
        "    animals = float(input(\"Livestock Count (animals/ha)       : \"))\n",
        "    n_runs  = int(input(\"Number of simulation runs [500]    : \") or \"500\")\n",
        "    return grass, animals, n_runs\n",
        "\n",
        "\n",
        "# --- MAIN ---\n",
        "if __name__ == \"__main__\":\n",
        "    grass, animals, n_runs = get_inputs()\n",
        "\n",
        "    print(f\"\\nRunning {n_runs} seasons WITH the Yacouba Loop...\")\n",
        "    with_finals, with_medians = monte_carlo(n_runs, grass, animals, system_active=True)\n",
        "\n",
        "    print(f\"Running {n_runs} seasons WITHOUT the Yacouba Loop...\")\n",
        "    no_finals, no_medians = monte_carlo(n_runs, grass, animals, system_active=False)\n",
        "\n",
        "    # Summary statistics\n",
        "    w_med = statistics.median(with_finals)\n",
        "    n_med = statistics.median(no_finals)\n",
        "    lift  = round((w_med - n_med) / max(1, n_med) * 100, 1)\n",
        "\n",
        "    print(\"\\n\" + \"=\" * 60)\n",
        "    print(\"  RESULTS SUMMARY — Kitwe Copperbelt (v3 with toxicity)\")\n",
        "    print(\"=\" * 60)\n",
        "    print(f\"  Median final biomass  WITH loop : {w_med:,.0f} kg/ha\")\n",
        "    print(f\"  Median final biomass  NO loop   : {n_med:,.0f} kg/ha\")\n",
        "    print(f\"  Biomass lift from system        : +{lift}%\")\n",
        "    print(f\"\\n  Land health (median, with loop) : {land_health_label(w_med)}\")\n",
        "    print(f\"  Land health (median, no loop)   : {land_health_label(n_med)}\")\n",
        "\n",
        "    print(\"\\n  RECOVERY PROBABILITIES\")\n",
        "    thresholds = [(2000, \"Thriving  (>2000 kg/ha)\"),\n",
        "                  (1000, \"Stable    (>1000 kg/ha)\"),\n",
        "                  (500,  \"Not degraded (>500 kg/ha)\")]\n",
        "    for t, label in thresholds:\n",
        "        wp = recovery_probability(with_finals, t)\n",
        "        np = recovery_probability(no_finals,   t)\n",
        "        print(f\"    {label}\")\n",
        "        print(f\"      With loop: {wp:5.1f}%   |   Without: {np:5.1f}%\")\n",
        "\n",
        "    print(\"\\n  TOXICITY MODEL\")\n",
        "    print(f\"    Initial suppression : {INITIAL_TOXICITY*100:.0f}%\")\n",
        "    print(f\"    Without loop        : stays at {INITIAL_TOXICITY*100:.0f}% permanently\")\n",
        "    print(f\"    With loop month 1   : {max(MIN_TOXICITY, INITIAL_TOXICITY - BIOCHAR_DETOX_RATE)*100:.0f}% toxicity\")\n",
        "    print(f\"    With loop month 3   : {max(MIN_TOXICITY, INITIAL_TOXICITY - BIOCHAR_DETOX_RATE*3)*100:.0f}% toxicity\")\n",
        "    print(f\"    With loop month 5   : {max(MIN_TOXICITY, INITIAL_TOXICITY - BIOCHAR_DETOX_RATE*5)*100:.0f}% toxicity\")\n",
        "    print(f\"    Residual floor      : {MIN_TOXICITY*100:.0f}%\")\n",
        "\n",
        "    print(\"\\n  DATA SOURCES\")\n",
        "    print(\"    Weather Atlas / climate-data.org — Kitwe rainfall (1999-2019)\")\n",
        "    print(\"    Gwanama et al. (2022) — Scientific Reports CBU — mine toxicity\")\n",
        "    print(\"    Ippolito et al. (2024) — biochar heavy metal immobilisation\")\n",
        "    print(\"    FAO/GIEWS — Livestock consumption standards\")\n",
        "    print(\"    Lehmann & Joseph (2015) — Biochar for Environmental Management\")\n",
        "    print(\"    UNCCD Field Data (2024)\")\n",
        "    print(\"=\" * 60)\n",
        "\n",
        "    plot_results(with_finals, no_finals, with_medians, no_medians)"
      ]
    }
